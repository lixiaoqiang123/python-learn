# 字节码文件
__pycache__/
*.py[cod]
*$py.class

# C 扩展文件
*.so

# 编译/分发目录
build/
develop-eggs/
dist/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
# 常见的虚拟环境目录名
venv/
.venv/
env/
ENV/
bin/
include/
share/
# 环境变量文件
.env
.flaskenv
secrets.json

# 证书与密钥文件
*.key
*.pem
# Jupyter Notebook 缓存
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# 数据集目录 (建议将原始数据放在独立文件夹)
data/
datasets/
*.csv
*.jsonl
*.parquet

# 模型权重与大型二进制文件
models/
*.bin
*.pt
*.pth
*.weights
*.h5
*.onnx

# 向量数据库本地持久化目录 (如 Milvus, Chroma)
db/
index/
# PyCharm 配置文件
.idea/

# VS Code 配置文件
.vscode/
*.code-workspace

# 操作系统临时文件
.DS_Store
Thumbs.db
.claude/settings.local.json
